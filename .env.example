APP_NAME="Trading Bot"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=trading_bot
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE=trading

TRADING_ENABLED=false
TRADING_MODE=paper
TRADING_DEFAULT_EXCHANGE=wallex
TRADING_QUEUE=trading
TRADING_LOCK_TTL=30
TRADING_MONITOR_INTERVAL=5
TRADING_EXIT_INTERVAL=30
TRADING_PAPER_QUOTE_BALANCE=1000000000
TRADING_HTTP_LOGGING_ENABLED=true

WALLEX_BASE_URL=https://api.wallex.ir/v1
WALLGOLD_BALANCES_URL=https://api.wallgold.ir/api/v1/account/balances
WALLEX_API_KEY=
WALLEX_TIMEOUT=10
WALLEX_RETRY_TIMES=3
WALLEX_RETRY_SLEEP_MS=250

MAIL_MAILER=log
